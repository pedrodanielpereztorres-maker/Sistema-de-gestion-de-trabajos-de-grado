+from ..database_manager import obtener_conexion
+
+logger = logging.getLogger(__name__)
+
+COLOR_FONDO_PAGINA = "#F8F9FF"
+COLOR_TARJETA = "white"
+COLOR_PRIMARIO = "#6366F1"
+COLOR_TEXTO_TITULO = "#0F172A"
