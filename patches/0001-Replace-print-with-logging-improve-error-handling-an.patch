+                letter_spacing="0.04em",
+                text_transform="uppercase",
+                line_height="1.4",
+            ),
+            spacing="0",
+            align="start",
+        ),
+        align="center",
+        spacing="3",
+        width="100%",
+        padding_x="16px",
+        padding_y="18px",
+        border_bottom=f"1px solid {COLOR_BORDE}",
+    )
+
+
+def pie_usuario() -> rx.Component:
+    return rx.vstack(
+        rx.hstack(
+            rx.center(
+                rx.text(
+                    EstadoAutenticacion.inicial_usuario,
