+
+def celda_texto(texto: str, secundario: bool = False) -> rx.Component:
+    return rx.table.cell(
+        rx.text(
+            texto,
+            color="#1E293B" if not secundario else "#475569",
+            font_weight="500",
+            font_size="14px"
+        ),
+        padding_y="16px", padding_x="20px"
+    )
