+def tarjeta_documento(doc: Documento) -> rx.Component:
+    tipo = doc.tipo.lower()
+
+    nombre_icono = rx.cond(
+        tipo.contains("pdf"), "file-text",
+        rx.cond(
+            tipo.contains("doc"), "file-type-2",
+            rx.cond(
+                tipo.contains("xls"), "file-spreadsheet",
+                "file"
+            )
+        )
+    )
+
+    color_icono = rx.cond(
+        tipo.contains("pdf"), COLOR_ICONO_PDF,
+        rx.cond(
+            tipo.contains("doc"), COLOR_ICONO_WORD,
+            rx.cond(
+                tipo.contains("xls"), COLOR_ICONO_EXCEL,
+                COLOR_ICONO_GENERICO
+            )
+        )
+    )
+
+    return rx.card(
+        rx.flex(
+            rx.hstack(
+                rx.center(
+                    rx.icon(nombre_icono, size=24, color=color_icono),
+                    width="48px", height="48px",
+                    background=color_icono + "15",
+                    border_radius="12px",
+                    border="1px solid " + color_icono + "30"
+                ),
+                rx.vstack(
+                    rx.text(doc.titulo, weight="bold",
+                            size="3", color="#0F172A"),
+                    rx.text(doc.descripcion, size="2",
+                            color="#1E293B", no_of_lines=2),
